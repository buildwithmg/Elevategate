# Copy to .env and fill in real values. Never commit the real .env.
#
# Generate strong random secrets, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"

# --- Used by `docker-compose.yml` (also fine to set these for local, non-Docker runs) ---

POSTGRES_PASSWORD=change-me

JWT_SECRET_KEY=change-me-to-a-long-random-value
JWT_EXPIRE_MINUTES=30

# Pre-shared secret an agent must present (X-Enrollment-Key header) to enroll. Not tied to any
# one device - rotate it if it leaks.
ENROLLMENT_KEY=change-me-to-a-long-random-value

APPROVAL_TTL_SECONDS=300
ELEVATION_REQUEST_TTL_SECONDS=3600

# --- Local (non-Docker) runs only ---
# Under Docker Compose, DATABASE_URL is constructed for you from POSTGRES_PASSWORD above, and
# the Ed25519 key is mounted as a file secret (see secrets/README.md) - these two lines are only
# needed when running `uvicorn app.main:app` directly on your machine.

DATABASE_URL=postgresql+psycopg://localhost/elevategate

# Exactly one of ED25519_PRIVATE_KEY_B64 / ED25519_PRIVATE_KEY_PATH should be set. Generate a
# keypair with the snippet in secrets/README.md. Never commit a real value here.
ED25519_PRIVATE_KEY_B64=
