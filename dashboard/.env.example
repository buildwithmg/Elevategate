# The dashboard's own server-side code (Route Handlers) talks to the FastAPI backend at this
# URL. It is never sent to the browser - the browser only ever talks to this Next.js app's own
# origin (see app/api/backend/[...path]/route.ts), so there is no NEXT_PUBLIC_* backend URL and
# no reason for one.
BACKEND_URL=http://localhost:8000
